# Microsoft Bot Framework credentials (from Azure Bot resource > Configuration)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
# MultiTenant (default) | SingleTenant | UserAssignedMSI
MICROSOFT_APP_TYPE=MultiTenant
# Required only when MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_APP_TENANTID=

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
PORT=3978
